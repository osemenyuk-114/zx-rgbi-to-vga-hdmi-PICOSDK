        "PATH": "${userHome}/.pico-sdk/toolchain/15_2_Rel1/bin:${userHome}/.pico-sdk/picotool/2.1.0/picotool:${userHome}/.pico-sdk/cmake/v3.31.5/bin:${userHome}/.pico-sdk/ninja/v1.12.1:${env:PATH}"
    },
    "terminal.integrated.env.linux": {
        "PICO_SDK_PATH": "${userHome}/.pico-sdk/sdk/2.2.0",
        "PICO_TOOLCHAIN_PATH": "${userHome}/.pico-sdk/toolchain/15_2_Rel1",
        "PATH": "${userHome}/.pico-sdk/toolchain/15_2_Rel1/bin:${userHome}/.pico-sdk/picotool/2.1.0/picotool:${userHome}/.pico-sdk/cmake/v3.31.5/bin:${userHome}/.pico-sdk/ninja/v1.12.1:${env:PATH}"
    },
    "raspberry-pi-pico.cmakeAutoConfigure": true,
    "raspberry-pi-pico.useCmakeTools": true,
    "raspberry-pi-pico.cmakePath": "${userHome}/.pico-sdk/cmake/v3.31.5/bin/cmake",
    "raspberry-pi-pico.ninjaPath": "${userHome}/.pico-sdk/ninja/v1.12.1/ninja"
