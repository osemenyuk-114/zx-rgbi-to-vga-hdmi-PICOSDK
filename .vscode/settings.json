{
    "cmake.options.statusBarVisibility": "hidden",
    "cmake.options.advanced": {
        "build": {
            "statusBarVisibility": "hidden"
        },
        "launch": {
            "statusBarVisibility": "hidden"
        },
        "debug": {
            "statusBarVisibility": "hidden"
        }
    },
    "cmake.useCMakePresets": "never",
    "cmake.configureOnEdit": true,
    "cmake.automaticReconfigure": true,
    "cmake.configureOnOpen": true,
    "cmake.generator": "Ninja",
    "cmake.cmakePath": "${userHome}/.pico-sdk/cmake/v3.31.5/bin/cmake",
    "cmake.environment": {
        "PICO_SDK_PATH": "${userHome}/.pico-sdk/sdk/2.2.0",
        "PICO_TOOLCHAIN_PATH": "${userHome}/.pico-sdk/toolchain/15_2_Rel1",
        "Path": "${userHome}/.pico-sdk/toolchain/15_2_Rel1/bin;${userHome}/.pico-sdk/ninja/v1.12.1;${userHome}/.pico-sdk/cmake/v3.31.5/bin;${env:PATH}"
    },
    "C_Cpp.debugShortcut": false,
    "terminal.integrated.env.windows": {
        "PICO_SDK_PATH": "${userHome}/.pico-sdk/sdk/2.2.0",
        "PICO_TOOLCHAIN_PATH": "${userHome}/.pico-sdk/toolchain/15_2_Rel1",
        "Path": "${userHome}/.pico-sdk/toolchain/15_2_Rel1/bin;${userHome}/.pico-sdk/picotool/2.1.0/picotool;${userHome}/.pico-sdk/cmake/v3.31.5/bin;${userHome}/.pico-sdk/ninja/v1.12.1;${env:PATH}"
    },
    "terminal.integrated.env.osx": {
        "PICO_SDK_PATH": "${userHome}/.pico-sdk/sdk/2.2.0",
